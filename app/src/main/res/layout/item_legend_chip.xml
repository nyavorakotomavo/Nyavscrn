<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_legend_chip"
    android:padding="@dimen/space_3"
    android:layout_marginBottom="@dimen/space_2">

    <View
        android:id="@+id/chipIndicator"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginEnd="@dimen/space_3"
        android:background="@drawable/bg_indicator_alive" />

    <TextView
        android:id="@+id/chipText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textAppearance="@style/TextAppearance.Nyavscrn.BodyMedium"
        android:textColor="@color/text_secondary" />

    <TextView
        android:id="@+id/chipCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.Nyavscrn.LabelLarge"
        android:textColor="@color/cyan_400" />

</LinearLayout>
