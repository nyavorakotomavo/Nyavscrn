<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/space_5">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_2"
            android:text="@string/result_title"
            android:textAppearance="@style/TextAppearance.Nyavscrn.HeadlineLarge"
            android:textColor="@color/text_primary" />

        <View
            android:layout_width="60dp"
            android:layout_height="3dp"
            android:layout_marginBottom="@dimen/space_6"
            android:background="@drawable/bg_severity_gradient" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_6"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="200dp"
                android:layout_weight="1.2"
                android:layout_marginEnd="@dimen/space_4"
                android:background="@drawable/bg_mini_grid_border"
                android:padding="2dp">

                <com.nyavo.nrscreen.test.MiniGridView
                    android:id="@+id/miniGrid"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="200dp"
                android:layout_weight="1"
                android:gravity="center">

                <com.nyavo.nrscreen.ui.DonutChartView
                    android:id="@+id/donutChart"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/donutPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textAppearance="@style/TextAppearance.Nyavscrn.HeadlineMedium"
                        android:textColor="@color/text_primary"
                        android:textSize="28sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="casse"
                        android:textAppearance="@style/TextAppearance.Nyavscrn.Caption"
                        android:textColor="@color/text_muted" />
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_2"
            android:text="Severite du dommage"
            android:textAppearance="@style/TextAppearance.Nyavscrn.BodyMedium"
            android:textColor="@color/text_secondary" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:layout_marginBottom="@dimen/space_1"
            android:background="@drawable/bg_severity_gradient"
            android:alpha="0.3" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:layout_marginBottom="@dimen/space_6">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_severity_gradient"
                android:alpha="0.15" />

            <View
                android:id="@+id/severityIndicator"
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="@color/white" />
        </FrameLayout>

        <!-- Le reste du fichier est ajouté dans la suite pour éviter une coupure Termux -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_3"
            android:text="Details"
            android:textAppearance="@style/TextAppearance.Nyavscrn.TitleLarge"
            android:textColor="@color/text_primary" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:layout_marginBottom="@dimen/space_6">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/space_1"
                android:background="@drawable/bg_card_surface"
                android:orientation="vertical"
                android:padding="@dimen/space_4">

                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginBottom="@dimen/space_2"
                    android:background="@drawable/bg_indicator_dead" />

                <com.nyavo.nrscreen.ui.AnimatedCounter
                    android:id="@+id/deadCounter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textAppearance="@style/TextAppearance.Nyavscrn.HeadlineMedium"
                    android:textColor="@color/void_500" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Zones mortes"
                    android:textAppearance="@style/TextAppearance.Nyavscrn.BodyMedium"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/space_1"
                android:background="@drawable/bg_card_surface"
                android:orientation="vertical"
                android:padding="@dimen/space_4">

                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginBottom="@dimen/space_2"
                    android:background="@drawable/bg_indicator_degraded" />

                <com.nyavo.nrscreen.ui.AnimatedCounter
                    android:id="@+id/degradedCounter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textAppearance="@style/TextAppearance.Nyavscrn.HeadlineMedium"
                    android:textColor="@color/nebula_500" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Zones degradees"
                    android:textAppearance="@style/TextAppearance.Nyavscrn.BodyMedium"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/space_1"
                android:background="@drawable/bg_card_surface"
                android:orientation="vertical"
                android:padding="@dimen/space_4">

                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginBottom="@dimen/space_2"
                    android:background="@drawable/bg_indicator_suspect" />

                <com.nyavo.nrscreen.ui.AnimatedCounter
                    android:id="@+id/suspectCounter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textAppearance="@style/TextAppearance.Nyavscrn.HeadlineMedium"
                    android:textColor="@color/star_400" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Zones suspectes"
                    android:textAppearance="@style/TextAppearance.Nyavscrn.BodyMedium"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/space_1"
                android:background="@drawable/bg_card_surface"
                android:orientation="vertical"
                android:padding="@dimen/space_4">

                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginBottom="@dimen/space_2"
                    android:background="@drawable/bg_indicator_alive" />

                <com.nyavo.nrscreen.ui.AnimatedCounter
                    android:id="@+id/aliveCounter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textAppearance="@style/TextAppearance.Nyavscrn.HeadlineMedium"
                    android:textColor="@color/cyan_400" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Zones OK"
                    android:textAppearance="@style/TextAppearance.Nyavscrn.BodyMedium"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

        </GridLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_3"
            android:text="Signification des couleurs"
            android:textAppearance="@style/TextAppearance.Nyavscrn.TitleLarge"
            android:textColor="@color/text_primary" />

        <LinearLayout
            android:id="@+id/legendContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="@dimen/space_8" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/restartButton"
            style="@style/Widget.Nyavscrn.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="@dimen/space_3"
            android:text="Nouveau test"
            android:textAppearance="@style/TextAppearance.Nyavscrn.LabelLarge"
            app:cornerRadius="@dimen/radius_full" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/shareButton"
            style="@style/Widget.Nyavscrn.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="@dimen/space_6"
            android:text="Partager le rapport"
            android:textAppearance="@style/TextAppearance.Nyavscrn.LabelLarge"
            app:cornerRadius="@dimen/radius_full" />

    </LinearLayout>

</ScrollView>
