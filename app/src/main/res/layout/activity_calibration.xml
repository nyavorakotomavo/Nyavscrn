<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.nyavo.nrscreen.test.GridTestView
        android:id="@+id/gridTestView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.15" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC0B0F1F" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <FrameLayout
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_marginBottom="@dimen/space_8">

            <ProgressBar
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:indeterminate="false"
                android:progressDrawable="@drawable/bg_countdown_ring"
                android:max="100"
                android:progress="100" />

            <ProgressBar
                android:id="@+id/countdownProgress"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:indeterminate="false"
                android:progressDrawable="@drawable/bg_progress_fill"
                android:max="5"
                android:progress="5"
                android:rotation="-90" />

            <TextView
                android:id="@+id/countdownNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="5"
                android:textAppearance="@style/TextAppearance.Nyavscrn.DisplayLarge"
                android:textColor="@color/nebula_400"
                android:textSize="72sp" />
        </FrameLayout>

        <TextView
            android:id="@+id/countdownText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Ne touchez pas l'ecran"
            android:textAppearance="@style/TextAppearance.Nyavscrn.HeadlineMedium"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_3"
            android:gravity="center"
            android:text="Calibration des zones fantomes"
            android:textAppearance="@style/TextAppearance.Nyavscrn.BodyMedium"
            android:textColor="@color/text_muted" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center|bottom"
        android:layout_marginBottom="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="@dimen/space_2"
            android:background="@drawable/bg_indicator_ghost"
            android:alpha="0.6" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detection des zones fantomes en cours..."
            android:textAppearance="@style/TextAppearance.Nyavscrn.Caption"
            android:textColor="@color/text_muted" />

    </LinearLayout>

</FrameLayout>
