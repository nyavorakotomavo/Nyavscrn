<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.nyavo.nrscreen.test.GridTestView
        android:id="@+id/gridTestView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:padding="@dimen/space_4">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginBottom="@dimen/space_2"
            android:background="@drawable/bg_card_surface">

            <View
                android:id="@+id/coverageBar"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_severity_gradient" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/coverageText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0%"
                android:textAppearance="@style/TextAppearance.Nyavscrn.Caption"
                android:textColor="@color/cyan_400" />

            <TextView
                android:id="@+id/cellsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 / 0"
                android:textAppearance="@style/TextAppearance.Nyavscrn.Caption"
                android:textColor="@color/text_muted" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/instructionContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center|bottom"
        android:layout_marginBottom="140dp"
        android:layout_marginHorizontal="@dimen/space_6"
        android:background="@drawable/bg_glassmorphism"
        android:padding="@dimen/space_4"
        android:gravity="center"
        android:orientation="horizontal">

        <View
            android:layout_width="4dp"
            android:layout_height="4dp"
            android:layout_marginEnd="@dimen/space_2"
            android:background="@drawable/bg_indicator_alive" />

        <TextView
            android:id="@+id/instructionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/test_instruction"
            android:textAppearance="@style/TextAppearance.Nyavscrn.BodyMedium"
            android:textColor="@color/text_primary"
            android:gravity="center" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/finishButton"
        style="@style/Widget.Nyavscrn.Button.Primary"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:paddingHorizontal="48dp"
        android:text="@string/action_finish"
        android:textAppearance="@style/TextAppearance.Nyavscrn.LabelLarge"
        android:visibility="gone"
        app:cornerRadius="@dimen/radius_full" />

</FrameLayout>
