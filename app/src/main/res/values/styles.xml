<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TextAppearance.Nyavscrn.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="android:fontFamily">@font/vt323</item>
        <item name="android:textColor">@color/on_background</item>
    </style>
    <style name="TextAppearance.Nyavscrn.DisplayMedium" parent="TextAppearance.Material3.DisplayMedium">
        <item name="android:fontFamily">@font/vt323</item>
        <item name="android:textColor">@color/on_background</item>
    </style>
    <style name="TextAppearance.Nyavscrn.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:fontFamily">@font/vt323</item>
        <item name="android:textColor">@color/on_background</item>
    </style>
    <style name="TextAppearance.Nyavscrn.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">@font/vt323</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>
    <style name="TextAppearance.Nyavscrn.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/vt323</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>
    <style name="TextAppearance.Nyavscrn.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:fontFamily">@font/vt323</item>
        <item name="android:textColor">@color/on_surface_variant</item>
    </style>
    <style name="TextAppearance.Nyavscrn.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/vt323</item>
        <item name="android:textColor">@color/on_surface_variant</item>
    </style>
    <style name="TextAppearance.Nyavscrn.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">@font/vt323</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>
    <style name="TextAppearance.Nyavscrn.Caption" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">@font/vt323</item>
        <item name="android:textColor">@color/text_muted</item>
    </style>

    <style name="Widget.Nyavscrn.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:fontFamily">@font/vt323</item>
        <item name="android:textSize">18sp</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="Widget.Nyavscrn.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:background">@drawable/bg_button_secondary</item>
        <item name="android:textColor">@color/cyan_400</item>
        <item name="android:fontFamily">@font/vt323</item>
        <item name="android:textSize">18sp</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="Widget.Nyavscrn.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">@dimen/radius_lg</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/outline</item>
    </style>

    <style name="Widget.Nyavscrn.Chip.Legend" parent="">
        <item name="android:background">@drawable/bg_legend_chip</item>
        <item name="android:paddingHorizontal">@dimen/space_3</item>
        <item name="android:paddingVertical">@dimen/space_2</item>
        <item name="android:textAppearance">@style/TextAppearance.Nyavscrn.BodyMedium</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
</resources>
